# Copy to config.toml and fill in. Local-only, gitignored.
#
# Every key here can also be supplied via env vars using the pattern
#   LILYGO_<SECTION>__<KEY>   (uppercased, double underscore between
#   section and key — single `_` is ambiguous because some keys contain it).
# Examples: LILYGO_METNO__EMAIL, LILYGO_LOCATION__LAT,
#           LILYGO_SERVER__RENDER_INTERVAL_S, LILYGO_HA__TOKEN.
# Precedence: env var > config.toml > built-in default.
# config.toml is optional when env vars cover the required keys
# (location.lat, location.lon, metno.email).

[server]
# Bind host/port for the HTTP server that the device polls.
host = "0.0.0.0"
port = 8080
# How often to re-render in seconds. met.no responses are still cached via
# If-Modified-Since, so most ticks are cheap 304s.
render_interval_s = 900
# Floor for on-GET re-rendering: a request will trigger a fresh render
# only if the cached buffer is older than this many seconds. Browser
# auto-refresh and burst polls within the window reuse the cache.
min_render_interval_s = 60

[location]
# Where met.no fetches the forecast for. Display also shows this label.
name = "Jarvenpaa"
lat = "60.4664"
lon = "25.0900"
timezone = "Europe/Helsinki"

[metno]
# met.no requires an identifying contact in User-Agent or returns 403.
# UA is built as "lilygo-eink/<version> <email>"; supply your email here.
email = "you@example.com"

[ha]
# Home Assistant base URL and a long-lived access token. Leave token empty
# to disable HA integration; the indoor temperature panel will show "--".
base_url = "http://homeassistant.local:8123"
token = ""
# Entity that holds the indoor temperature reading.
entity_indoor = "sensor.living_room_temperature"
